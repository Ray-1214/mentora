{
  "name": "toeic-drill",
  "version": "1.1.0",
  "private": true,
  "homepage": ".",
  "main": "public/electron.js",
  "author": {
    "name": "TOEIC Drill"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "dotenv": "^17.4.2",
    "electron-is-dev": "^2.0.0",
    "electron-store": "^8.1.0",
    "openai": "^4.47.1",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "electron": "electron .",
    "electron-dev": "concurrently \"cross-env BROWSER=none NODE_TLS_REJECT_UNAUTHORIZED=0 npm start\" \"wait-on http://localhost:3000 && cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 electron .\"",
    "electron-build": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 npm run build && cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 electron-builder --win",
    "release": "powershell -ExecutionPolicy Bypass -File scripts/release.ps1"
  },
  "build": {
    "appId": "com.toeic.drill",
    "productName": "TOEIC Drill",
    "asar": true,
    "files": [
      "build/**/*",
      "public/electron.js",
      "public/preload.js"
    ],
    "extraResources": [],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TOEIC Drill",
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  }
}
